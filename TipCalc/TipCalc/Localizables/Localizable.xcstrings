    "Saving money is giving your future self a gift security, freedom, and peace of mind wrapped in every dollar set aside." : {
      "localizations" : {
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ahorrar dinero es darle a tu yo futuro un regalo: seguridad, libertad y tranquilidad envuelto en cada dólar reservado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Épargner, c'est offrir à votre futur moi un cadeau : sécurité, liberté et sérénité dans chaque dollar mis de côté."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sparen ist ein Geschenk an dein zukünftiges Ich: Sicherheit, Freiheit und Gelassenheit in jedem zurückgelegten Dollar."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "貯金は未来の自分への贈り物。貯めたひとつひとつのドルに、安心、自由、心の平和が込められています。"
          }
        }
      }
    },
