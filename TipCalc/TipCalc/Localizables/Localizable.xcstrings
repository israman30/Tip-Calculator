    "Open Saved Bills and tap Insights to see your spending overview: total expenses, tips paid, and split bills across categories." : {
      "comment" : "Onboarding tip 4 body",
      "localizations" : {
        "es-419" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre las facturas guardadas y toca «Insights» para ver tu resumen de gastos: gastos totales, propinas pagadas y facturas desglosadas por categorías."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouvrez les additions enregistrées et touchez « Statistiques » pour voir votre récapitulatif de dépenses : total des dépenses, pourboires versés et additions partagées par catégorie."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffne gespeicherte Rechnungen und tippe auf „Statistiken“, um deine Auswertung zu sehen: Gesamtausgaben, Trinkgelder und geteilte Rechnungen nach Kategorie."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "保存したお会計を開き「統計」をタップして支出の概要を確認：総支出、支払ったチップ、カテゴリ別の割り勘。"
          }
        }
      }
    },
